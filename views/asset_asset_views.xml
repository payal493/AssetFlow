<odoo>
    <record id="view_asset_asset_tree" model="ir.ui.view">
        <field name="name">asset.asset.tree</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <list string="Assets">
                <field name="asset_tag"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="current_holder_id"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_asset_asset_form" model="ir.ui.view">
        <field name="name">asset.asset.form</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <form string="Asset">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Asset Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Asset Information">
                            <field name="asset_tag" readonly="1"/>
                            <field name="name"/>
                            <field name="category_id"/>
                            <field name="current_holder_id"/>
                            <field name="location"/>
                        </group>
                        <group string="Acquisition Information">
                            <field name="serial_number"/>
                            <field name="acquisition_date"/>
                            <field name="acquisition_cost"/>
                        </group>
                    </group>
                    <group string="Status Information">
                        <group>
                            <field name="condition"/>
                            <field name="status"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_asset_asset_search" model="ir.ui.view">
        <field name="name">asset.asset.search</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <search string="Assets">
                <field name="asset_tag"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="status"/>
                <field name="current_holder_id"/>
                <field name="location"/>

                <filter name="available" string="Available" domain="[('status', '=', 'available')]"/>
                <filter name="allocated" string="Allocated" domain="[('status', '=', 'allocated')]"/>
                <filter name="maintenance" string="Maintenance" domain="[('status', '=', 'under_maintenance')]"/>
                <filter name="lost" string="Lost" domain="[('status', '=', 'lost')]"/>
                <filter name="retired" string="Retired" domain="[('status', '=', 'retired')]"/>
            </search>
        </field>
    </record>

    <record id="view_asset_transfer_form" model="ir.ui.view">
        <field name="name">asset.transfer.form</field>
        <field name="model">asset.transfer</field>
        <field name="arch" type="xml">
            <form string="Asset Transfer">
                <header>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state != 'requested'"/>
                    <button name="action_reject" type="object" string="Reject" invisible="state != 'requested'"/>
                    <button name="action_complete" type="object" string="Complete" class="btn-primary" invisible="state != 'approved'"/>
                    <field name="state" widget="statusbar" statusbar_visible="requested,approved,rejected,completed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="asset_id"/>
                            <field name="current_holder_id" readonly="1"/>
                            <field name="new_holder_id"/>
                        </group>
                        <group>
                            <field name="request_date"/>
                            <field name="approval_date" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason" colspan="4" nolabel="1" placeholder="Reason for transfer..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>